# Primary base domain used by stack routes
DOMAIN=example.com

# Prometheus basic auth username
PROMETHEUS_USER=admin

# Prometheus basic auth password hash for Caddy
# Generate with: docker run --rm caddy caddy hash-password --plaintext 'your-password'
PROMETHEUS_HASHED_PASSWORD=

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
