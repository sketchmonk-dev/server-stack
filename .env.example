# =============================================================================
# grafana/otel-lgtm - environment configuration
# Copy this file to .env and adjust values before running docker compose up
# =============================================================================

# ── Domain ────────────────────────────────────────────────────────────────────
# caddy-docker-proxy routes each subdomain via Caddy (HTTPS + auto cert).
# No ports are exposed on the host.
#
#   grafana.${DOMAIN}     → Grafana UI
#   prometheus.${DOMAIN}  → Prometheus UI
#   pyroscope.${DOMAIN}   → Pyroscope UI
#   otlp.${DOMAIN}        → OTel Collector HTTP/protobuf (port 4318)
#   otlp-grpc.${DOMAIN}   → OTel Collector gRPC          (port 4317)
#
DOMAIN=example.com

# ── Grafana credentials ───────────────────────────────────────────────────────
# These are now publicly reachable via Caddy - use strong values!
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# ── Grafana SMTP ───────────────────────────────────────────────────────────────
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=alerts@example.com
GF_SMTP_PASSWORD=your-app-password
GF_SMTP_FROM_ADDRESS=alerts@example.com
GF_SMTP_FROM_NAME=Grafana
# OpportunisticStartTLS | MandatoryStartTLS | NoStartTLS
GF_SMTP_STARTTLS_POLICY=MandatoryStartTLS
GF_SMTP_SKIP_VERIFY=false

# ── Enable verbose logging per component (true / false) ───────────────────────
ENABLE_LOGS_GRAFANA=false
ENABLE_LOGS_LOKI=false
ENABLE_LOGS_PROMETHEUS=false
ENABLE_LOGS_TEMPO=false
ENABLE_LOGS_PYROSCOPE=false
ENABLE_LOGS_OTELCOL=false
ENABLE_LOGS_ALL=false


# ── OBI - eBPF auto-instrumentation ──────────────────────────────────────────
# Requires Linux kernel 5.8+ with BTF.
# When true, also uncomment `pid: host` and `privileged: true` in compose file.
ENABLE_OBI=false

# Target language / process (only used when ENABLE_OBI=true).
# Values: java | python | node | dotnet | ruby | <executable-name-regex>
OBI_TARGET=


# ── Forward telemetry to an external OTLP endpoint (optional) ────────────────
# Grafana Cloud example:
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-0.grafana.net/otlp
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instanceID:apiToken)>
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=


# ── Pre-install Grafana plugins ───────────────────────────────────────────────
# Comma-separated plugin IDs, e.g. grafana-piechart-panel,grafana-clock-panel
GF_PLUGINS_PREINSTALL=


# ── Your application's OTel SDK settings ─────────────────────────────────────
# For apps in the same compose network, use the internal service name (no TLS):
#
#   OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://lgtm:4318
#
# For external apps, send to the public Caddy-terminated endpoints:
#
#   OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.example.com
#
#   For gRPC:
#   OTEL_EXPORTER_OTLP_PROTOCOL=grpc
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-grpc.example.com