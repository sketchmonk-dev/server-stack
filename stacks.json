{
    "caddy": {
        "directory": "stacks/caddy",
        "dockerComposeFile": "docker-compose.yml"
    },
    "portainer": {
        "directory": "stacks/portainer",
        "dockerComposeFile": "docker-compose.yml",
        "env": ["DOMAIN"]
    },
    "monitoring": {
        "directory": "stacks/monitoring",
        "dockerComposeFile": "docker-compose.yml",
        "env": [
            "DOMAIN",
            "ENABLE_LOGS_ALL",
            "ENABLE_LOGS_GRAFANA",
            "ENABLE_LOGS_LOKI",
            "ENABLE_LOGS_OTELCOL",
            "ENABLE_LOGS_PROMETHEUS",
            "ENABLE_LOGS_PYROSCOPE",
            "ENABLE_LOGS_TEMPO",
            "ENABLE_OBI",
            "GF_PLUGINS_PREINSTALL",
            "GF_SECURITY_ADMIN_PASSWORD",
            "GF_SECURITY_ADMIN_USER",
            "GF_SMTP_FROM_ADDRESS",
            "GF_SMTP_FROM_NAME",
            "GF_SMTP_HOST",
            "GF_SMTP_PASSWORD",
            "GF_SMTP_SKIP_VERIFY",
            "GF_SMTP_STARTTLS_POLICY",
            "GF_SMTP_USER",
            "OBI_TARGET",
            "OTEL_EXPORTER_OTLP_ENDPOINT",
            "OTEL_EXPORTER_OTLP_HEADERS",
            "PROMETHEUS_HASHED_PASSWORD"
        ]
    }
}